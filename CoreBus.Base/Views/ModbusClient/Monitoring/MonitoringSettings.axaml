<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" 
			 d:DesignWidth="1100" d:DesignHeight="110"
             xmlns:ViewModels="clr-namespace:ViewModels.ModbusClient.Monitoring;assembly=ViewModels"
             x:Class="CoreBus.Base.Views.ModbusClient.Monitoring.MonitoringSettings"
             x:DataType="ViewModels:ModbusMonitoring_VM">

    <Grid>
					
        <StackPanel Orientation="Vertical" Spacing="15"
					Width="403"
					Margin="20,10,0,0"
					HorizontalAlignment="Left">

			<StackPanel Orientation="Horizontal" Spacing="15">
				
				<TextBlock Text="Функция опроса"
						   Foreground="{DynamicResource App_Color_Text}" 
						   VerticalAlignment="Center"/>

				<ComboBox ItemsSource="{Binding ReadFunctions}"
						  SelectedItem="{Binding SelectedReadFunction, Mode=TwoWay}"
						  Width="275"
						  MinHeight="5"
						  Height="30"
						  FontSize="14"
						  VerticalAlignment="Center"/>

			</StackPanel>

			<Grid>
							
				<StackPanel Orientation="Horizontal" Spacing="15">

				<TextBlock Text="Период"
							Width="55"
							VerticalAlignment="Center"/>

				<TextBox Classes="InputField"
						 Width="60"
						 MinHeight="5"
						 Height="30"
						 Text="{Binding Period_ms, Mode=TwoWay}"
						 IsEnabled="{Binding !IsStart, Mode=OneWay}"
						 VerticalAlignment="Center"/>

				<TextBlock Text="мс."
						   VerticalAlignment="Center"/>

			</StackPanel>

			<Button Width="150"
					FontSize="14"
					Content="{Binding Button_Content, Mode=OneWay}"
					IsEnabled="{Binding UI_IsEnable}"
					HorizontalAlignment="Right"
					Command="{Binding Command_Start_Stop_Polling}"/>

			</Grid>

		</StackPanel>

		<StackPanel Orientation="Vertical" Spacing="15"
				    IsVisible="{Binding HasSelectedItems, Mode=OneWay}"
					Margin="0,10,20,0"
					HorizontalAlignment="Right">

			<Button Content="Удалить выбранные регистры"
					FontSize="14"
					Command="{Binding Command_RemoveSelectedItems}"/>

			<CheckBox Content="Опрашивать выбранные регистры"
					  Foreground="{DynamicResource App_Color_Text}"
					  IsChecked="{Binding ShouldPollSelectedRegisters, Mode=TwoWay}"/>

		</StackPanel>

	</Grid>

</UserControl>
